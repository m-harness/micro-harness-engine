# === Required ===
# Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-api03-...

# Admin console password (used by the protected "root" account)
ADMIN_RUNTIME_PASSWORD=change-me-to-a-strong-password

# === Optional ===
# LLM_PROVIDER=anthropic
# LLM_MAX_TOKENS=1400
# API_PORT=4310
# PROJECT_ROOT_DIR=.
# APP_DB_PATH=app-v2.db

# Session / cookie
# AUTH_SESSION_TTL_HOURS=336
# ADMIN_SESSION_TTL_HOURS=12
# AUTH_COOKIE_NAME=myclaw_session
# ADMIN_AUTH_COOKIE_NAME=myclaw_admin_session

# CORS (comma-separated origins, empty = localhost only)
# ALLOWED_ORIGINS=

# Slack integration
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=

# Discord integration
# DISCORD_BOT_TOKEN=
# DISCORD_PUBLIC_KEY=
# DISCORD_APPLICATION_ID=

# Automation scheduler tick interval (ms)
# AUTOMATION_TICK_MS=30000
